# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI (embeddings)
OPENAI_API_KEY=your-openai-api-key-here

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Zoho Desk OAuth
ZOHO_DESK_REFRESH_TOKEN=your-zoho-refresh-token-here
ZOHO_DESK_CLIENT_ID=your-zoho-client-id-here
ZOHO_DESK_CLIENT_SECRET=your-zoho-client-secret-here

# Shopify
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=your-shopify-admin-token-here

# Webhook auth for /api/ingest
# Generate with: openssl rand -hex 32
# Must match the x-ingest-secret header value configured in the Zoho webhook
INGEST_SECRET=your-ingest-secret-here
